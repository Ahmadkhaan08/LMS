{
  "compilerOptions": {
    /* Module system */
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    /* Target */
    "target": "ES2020",
    "lib": ["ES2020"],

    /* Node */
    "types": ["node"],

    /* Output */
    "outDir": "./dist",
    "rootDir": "./",

    "sourceMap": true,
    "declaration": false,

    /* Strictness */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    /* Module behavior */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    /* Dev experience */
    "skipLibCheck": true
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}